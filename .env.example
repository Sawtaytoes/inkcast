# Inkcast server configuration — copy to `.env` and fill in.
# `.env` is gitignored; NEVER commit real hostnames, passwords, or device MACs.

# --- HTTP API ---
# Port the Hono API listens on.
PORT=8788
# Bearer token required by the API (generate a long random string).
# Leave empty to disable auth (LAN-only / development).
INKCAST_API_TOKEN=

# --- Rendering ---
# Which render engine to use: "chromium" (faithful, recommended) or "satori"
# (lighter, diverges on complex layouts). Both are kept available.
INKCAST_RENDER_ENGINE=chromium

# --- Devices ---
# Path to a JSON array of your real devices (gitignored). If unset, the built-in
# EXAMPLE devices are used. Shape: DeviceMetadata[] (see @inkcast/core).
# INKCAST_DEVICES_FILE=./inkcast.config.json

# --- MQTT / Home Assistant ---
# Broker URL. Use mqtts:// for the SSL listener (port 8883), mqtt:// for plain
# (1883). Point the hostname at whatever the broker's TLS cert is issued for.
#   Plain (LAN):  mqtt://homeassistant.local:1883
#   TLS:          mqtts://homeassistant.local:8883
# Leave empty to run the server with MQTT disabled (no HA push).
MQTT_URL=
# Credentials of a dedicated Home Assistant user for Inkcast.
MQTT_USERNAME=
MQTT_PASSWORD=
# TLS only: path to the broker's CA cert if it isn't publicly trusted.
# MQTT_CA_FILE=./certs/ha-ca.pem
# TLS only: set to "false" to accept a self-signed / name-mismatched cert.
MQTT_REJECT_UNAUTHORIZED=true

# Home Assistant MQTT discovery settings (defaults are usually fine).
MQTT_DISCOVERY_PREFIX=homeassistant
MQTT_NODE_ID=inkcast
MQTT_BASE_TOPIC=inkcast

# Timezone for time-based views.
TZ=America/Chicago
