{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    // DOM + jsx are needed because the server consumes @castkit/render and
    // @castkit/views *source*: the Chromium engine references `document`
    // (inside page.evaluate) and the views are .tsx.
    "lib": ["DOM", "DOM.Iterable", "ESNext"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "jsx": "react-jsx",
    "types": ["node"],
    "noEmit": true
  },
  "include": ["src/**/*", "vitest.config.ts"]
}
