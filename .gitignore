.yarn/cache
.yarn/unplugged
.yarn/build-state.yml
.yarn/install-state.gz
.yarn/sdks

# Yarn PnP runtime (regenerated by `yarn install`; not zero-install here)
.pnp.*

build/
dist/
node_modules/
storybook-static/

# Render/dither bake-off output — regenerated artifacts, never committed
render-output/
**/render-output/

.cache
.config

# Secrets + anything house-specific (creds, hostnames, real device MACs/names,
# TLS certs). NEVER commit these — the repo is public. Only *.example is tracked.
.env
.env.*
!.env.example
inkcast.config.*
!inkcast.config.example.*
devices.json
*.local.json
# ESPHome per-device secrets (wifi + API key) — kept next to the .yaml, never committed
device-client/esphome/secrets.yaml
device-client/**/secrets.yaml
# TLS material for the MQTT broker connection
certs/
*.pem
*.crt
*.key

# Playwright artifacts
playwright-report/
test-results/
.playwright-mcp/

# Vitest browser-mode failure screenshots
**/__screenshots__/
**/.vitest-attachments/

# Claude Code per-machine permission overrides
.claude/settings.local.json
.claude/worktrees/
.claude/scheduled_tasks.lock

*.log

# Python bytecode
__pycache__/
*.pyc
